<%- include("../includes/top_part.ejs"); %>
<script src="/js/axios.min.js"></script>
<link rel="stylesheet" href="/css/user/profile.css" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="profile">
  <div class="container">
    <div class="row">
      <div class="col-12 mb-5" x-data="{testing: 'test', userData: {}, payments: {}, round: {}, userGrades: {}}"
           x-init="
           userData = (await axios.get('/user-data')).data.user;
           payments = (await axios.get('/user-payments')).data;
           round = (await axios.get('/user-round')).data;
           userGrades = (await axios.get('/user-grades')).data;
          ">
        <%- include("../includes/errorMessage.ejs"); %>
        <div class="custom-head">
          <h2>Your Data</h2>
          <span></span>
        </div>
        <div class="user-content">
          <div class="info">
            Name
          </div>

          <div class="info" x-text="userData.name">
          </div>
          <div class="info">
            Phone Number
          </div>

          <div class="info" x-text="userData.whatsapp_no">
          </div>
          <div class="info">
            Email
          </div>

          <div class="info" x-text="userData.email">
          </div>

          <div class="info">
            Specialization
          </div>

          <div class="info" x-text="userData.specialization">
          </div>

          <div class="info">
            Your Courses
          </div>

          <div class="info payments-details">
            <div x-show="payments">
              <template x-for="payment in payments.payments">
                <div class="bought_courses" x-data="{payment}">
                  <span x-text="payment.name"></span>
                  <span x-text="payment.price"></span>
                </div>
              </template>
            </div>
            <div x-show="payments.payments == []">
              <span x-text="payments.message"></span>
            </div>
          </div>

          <div class="info" x-show="round.round">
            Round files
          </div>
          <div class="info" x-show="round" x-html="round.round">
          </div>

          <!--<div class="info" x-text="JSON.stringify(userGrades.userExams)"></div>-->

          <div class="info" x-show="userGrades.userExams">
            Your performed exams: <br />
            <div class="exams-previews">
              <template x-for="(grade, index) in userGrades.userExams">
                <div x-data="grade" :class="'preview-' + index" class="fs-5">
                  <span x-text="index + 1 + ': '"></span>
                  <a :href="grade.preview_link" x-text="grade.title + ' report'"></a>
                </div>
              </template>
            </div>
          </div>

          <div class="info payments-details" x-show="userGrades.userGrades">
            <template x-for="(grade, index) in userGrades.userExams">
              <div class="bought_courses" x-data="{grade}">
                <span class="text-center">
                  <sup><span x-text="grade.reply.grade"></span></sup> /
                  <sub><span x-text="grade.reply.userAnswers.length"></span></sub>
                </span>
              </div>
            </template>
          </div>

          <% if (courseName) { %>
            <div class="info">
              Your Certificate
            </div>

            <div class="info">
              <a href="/certificates/<%- courseId %>" class="link-success"><%= courseName.name %>
                - <%= moment(roundDate).format("LL") %></a>
            </div>
          <% } %>

          <div class="info">
            <a href="/update-data/<%= user.user_id %>" class="btn">
              Update your data?
            </a>
          </div>

        </div>
      </div>
      <div class="col-12">
        <div class="row">
          <div class="col-lg-6 col-xs-12">
            <div class="user-img">
              <% if (user.user_img) { %>
                <img
                  src="/downloaded_images/<%= user.user_img %>"
                  alt="<%= user.name %>"
                />
              <% } else { %>
                <div class="alert alert-primary" role="alert">
                  Do you want to add an image ?
                </div>
                <img
                  src="/imgs/imgs/user_img.png"
                  alt="<%= user.name %>"
                />
              <% } %>
            </div>
          </div>
          <div class="col-lg-5 col-xs-12">
            <form action="/update-user-img" method="POST" enctype="multipart/form-data">
              <div class="custom-input">
                <input type="file" name="user_img" id="user_img" placeholder="Update your image"
                       class="form-control <%= validationError.error === "img" ? "is-invalid" : "" %>">
              </div>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-outlined">
                update image
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

