<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/auth/login.css"/>
</head>
<body>
<%- include("../includes/navigation.ejs"); %>


<section class="login-form">
  <div class="container content-container">
    <div class="">
      <h2>Update Your Data</h2>
      <div class="header-dash-line"></div>
    </div>
    <%- include('../includes/errorMessage.ejs'); %>
    <form action="/update-data" method="POST" novalidate class="">
      <div class="form-floating my-3">
        <input type="text" name="name" id="name" placeholder="Your email"
               disabled
               class="form-control <%= validationErrors.name ? "is-invalid" : "" %>"
               value="<%= user.name %>"/>
        <label for="name">Your name</label>
      </div>

      <div class="form-floating my-3">
        <input type="email" name="email" id="email" placeholder="Your email"
               class="form-control <%= validationErrors.email ? "is-invalid" : "" %>"
               value="<%= user.email %>"/>
        <label for="email">Your Email</label>
      </div>

      <div class="form-floating my-3">
        <input type="tel" name="whatsapp_number" id="number" placeholder="Your email"
               class="form-control <%= validationErrors.whatsapp_no ? "is-invalid" : "" %>"
               value="<%= user.whatsapp_no %>"/>
        <label for="number">Your Number</label>
      </div>

      <div class="form-floating my-3">
        <input type="text" name="specialization" id="specialization" placeholder="Your specialization"
               class="form-control <%= validationErrors.specialization ? "is-invalid" : "" %>"
               value="<%= user.specialization %>"/>
        <label for="specialization">Your Specialization</label>
      </div>


      <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
      <button class="btn">
        Update your data
      </button>
    </form>
  </div>
</section>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>