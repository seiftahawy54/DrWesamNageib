<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/user/profile.css" />
<link rel="stylesheet" href="/css/user/exam.css" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="exam">
  <div class="container">
    <% if (!exam) { %>
      <div class="alert fs-4 text-center alert-danger" role="alert">
        Wrong exam link!
      </div>
    <% } else if (!exam.status) { %>
      <div class="alert fs-4 text-center alert-danger" role="alert">
        This Exam Is Closed
      </div>
    <% } else { %>
      <div class="alert fs-4 text-center alert-danger d-none" role="alert" id="alert-message">

      </div>
      <div class="custom-head">
        <h2 class="h1 text-center"><%- exam.title %></h2>
        <span class="mx-auto"></span>
      </div>
      <div class="row">
        <div class="offset-lg-3 col-lg-6 col-xs-12">
          <div class="question-container" id="questionsContainer">
            <form id="exam-form">
              <% exam.questions.forEach(({ questionHeader, answers }, questionIndex) => { %>
                <div class="question">
                  <div class="custom-head">
                    <h4>Q<sub><%= questionIndex + 1 %></sub> - <%= questionHeader %></h4>
                    <span></span>
                  </div>
                  <div class="answers-container">
                    <% answers.forEach((answer, answerIndex)=> { %>
                      <div class="form-check my-3 answer">
                        <input class="form-check-input" type="radio"
                               id="q-<%- questionIndex + 1 %>-answer-<%- answerIndex + 1 %>"
                               name="answer-<%- questionIndex %>">
                        <label class="form-check-label w-100"
                               for="q-<%- questionIndex + 1 %>-answer-<%- answerIndex + 1 %>">
                          <%- answer %>
                        </label>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </form>
          </div>
        </div>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" id="csrfToken" />
        <input type="hidden" value="<%- exam.exam_id %>" name="examId" id="examId">
        <div class="offset-3 col-6">
          <div class="submit-container">
            <button class="btn" id="submit-exam">Submit Exam</button>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<script src="/js/axios.min.js"></script>
<script src="/js/users/exam.js"></script>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>
