<script>
  const editorTag = document.querySelector(".editor-<%- course.course_id %>");
  let editor;
  ClassicEditor
    .create(editorTag, {
      toolbar: ['bold', 'italic', 'bulletedList', 'numberedList']
    })
    .then(editorData => {
      editor = editorData;

      <% if (editMode === 'true') { %>
      editor.setData("<%- course.description %>")
      <% } %>
    })
    .catch(err => {
      console.error(err)
    })

  ClassicEditor.replaceAll();
</script>