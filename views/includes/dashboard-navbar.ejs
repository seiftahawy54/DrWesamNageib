<div class="show-nav remove-show-button" id="show-nav-button">
  <button class="navbar-toggler d-sm-block d-lg-none" type="button">
    <span class="navbar-toggler-icon">
    <%- include('../../public/imgs/svgs/navbar_icon.svg') %>
  </span>
  </button>
</div>

<script>
  const navigationButton = document.querySelector("#nav-button")
  const dashboardNavigation = document.querySelector("#dashboard-navbar")
  const showNavButton = document.querySelector("#show-nav-button")

  navigationButton.addEventListener("click", (btn) => {
    dashboardNavigation.classList.toggle("remove-nav")
    showNavButton.classList.remove("remove-show-button")
    showNavButton.classList.toggle("active")
  })

  showNavButton.addEventListener("click", () => {
    showNavButton.classList.toggle("active")
    dashboardNavigation.classList.remove("remove-nav")
    showNavButton.classList.remove("remove-show-button")
  })

  navigationButton.click()

</script>
