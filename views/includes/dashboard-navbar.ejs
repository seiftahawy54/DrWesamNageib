        </span>
      </button>
    </div>
    <div class="logged-in-user">
      <div class="user-img">
        <img src="/imgs/imgs/userthumbnail.png" alt="user-thumbnail" />
      </div>
      <div class="user-info">
      <span class="user-type">
      Owner
    </span>
        <span class="user-name">
      Dr. Wesam
    </span>
      </div>
    </div>
    <div class="nav-links">
      <ul class="list-unstyled">
        <%- include('./navlinks', {routeName: "overview", linkText: "Overview" }); %>
        <%- include('./navlinks', {routeName: "users", linkText: "Users" }); %>
        <%- include('./navlinks', {routeName: "rounds", linkText: "Rounds" }); %>
        <%- include('./navlinks', {routeName: "courses", linkText: "Courses" }); %>
        <%- include('./navlinks', {routeName: "messages", linkText: "Messages" }); %>
        <%- include('./navlinks', {routeName: "opinions", linkText: "Opinions" }); %>
