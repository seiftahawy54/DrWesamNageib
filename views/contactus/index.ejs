<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/contactus/index.css" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="contact-us">
  <div class="container">
    <div class="row">
      <div class="col-lg offset-xl-1">
        <% if (errorMessage) { %>
          <div class="error-container">
            <%- errorMessage; %>
          </div>
        <% } %>
        <% if (successMessage) { %>
          <div class="error-container">
            <div class="alert fs-4 text-center alert-primary" role="alert">
              <%- successMessage %>
            </div>
          </div>
        <% } %>
        <div class="custom-head">
          <h3>Contact for any issues</h3>
          <span></span>
        </div>
        <form action="/contact" method="POST" id="contact-form">
          <div class="form-floating my-3">
            <input type="text" name="contact_name" id="contact_name" class="form-control"
                   placeholder="Your name" />
            <label for="contact_name">Your name</label>
          </div>
          <div class="form-floating my-3">
            <input type="email" name="contact_email" id="contact_email" placeholder="Your email" class="form-control" />
            <label for="contact_email">Your email</label>
          </div>
          <div class="d-none">
            <input type="text" id="dummy-field" class="form-control" />
          </div>
          <div class="form-floating my-3">
            <textarea name="contact_content" id="contact_content" placeholder="Enter your message" class="form-control"
                      cols="30" rows="30"></textarea>
            <label for="contact_content">Your Message</label>
          </div>
          <input type="hidden" name="_csrf" value="<%= csrfToken; %>" />
          <button class="btn" type="submit">Send your message</button>
        </form>
      </div>
      <div class="col-1 offset-lg-1 d-lg-block d-none">
        <div class="separator"></div>
      </div>
      <div class="col-lg">
        <aside class="contact-alternative">
          <a href="https://wa.me/966548794731" target="_blank" class="reset-link">
            <%- include('../../public/imgs/svgs/whatsapp.svg') %>
            Message On Whatsapp
          </a>
          <a href="tel:966548794731" target="_blank" class="reset-link">
            <%- include('../../public/imgs/svgs/phone.svg') %>
            +9665 4879 4731
          </a>
          <a href="mailto:drwesamnageib@gmail.com" target="_blank" class="reset-link">
            <%- include('../../public/imgs/svgs/email.svg') %>
            drwesamnageib@gmail.com
          </a>
        </aside>
      </div>
    </div>
  </div>
</section>

<script>
  'use-strict';

  const dummyField = document.getElementById("dummy-field")
  const contactFormElement = document.getElementById("contact-form")
  contactFormElement.addEventListener("submit", (e) => {
    e.preventDefault();
    if (dummyField.value.length === 0) {
      contactFormElement.submit();
    }
  })
</script>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>
