<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/auth/login.css" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="login-form forget-password">
  <div class="container content-container">
    <div>
      <h2 class="custom-head align-items-center">
        Return your account
        <span></span>
      </h2>
    </div>
    <form action="/forget-password" method="post" class="col-xs-12 col-6">
      <div class="form-floating my-3">
        <input type="email" name="user_email" placeholder="email"
               class="form-control <%= validationErrors.find(e => e.param === "user_email") ? "is-invalid border-danger" : "" %>"
               value="<%- enteredData.email %>"
               id="round_date" />
        <label for="round_date">Your Email</label>
        <% if (validationErrors.findIndex(e => e.param === "user_email") !== -1) { %>
          <p
            class="text-danger"> <%= validationErrors[validationErrors.findIndex(e => e.param === "user_email")].msg %></p>
        <% } %>
      </div>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn" type="submit">Reset password</button>
    </form>
  </div>
</section>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>
