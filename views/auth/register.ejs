<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/auth/login.css" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="register-form">
    <div class="content-container">
        <h2>Register</h2>
        <div class="header-dash-line"></div>
        <form action="/register" method="POST">
            <div class="my-form-control">
                <input type="text" name="name" id="name" placeholder="Enter your name" />
            </div>
            <div class="my-form-control">
                <input type="email" name="email" id="email" placeholder="Enter your email" />
            </div>
            <div class="my-form-control">
                <input type="password" name="password" id="password" placeholder="Enter your password" />
            </div>
            <div class="my-form-control">
                <input type="password" name="confirm_password" id="confirm_password" placeholder="Confirm your password" />
            </div>
            <div class="my-form-control">
                <input type="tel" name="phone_number" id="phone_number" placeholder="Enter your number (with international key)" />
            </div>
            <div class="my-form-control">
                <input type="url" name="telegram_handle" id="telegram_handle" placeholder="Enter your telegram handle" />
            </div>
            <div class="login-options">
                <a href="/login" class="reset-link">Have an account? Login</a>
            </div>
            <button class="btn">
                Register
            </button>
        </form>
    </div>
</section>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>
