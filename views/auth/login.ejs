<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/auth/login.css"/>
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<section class="login-form">
  <% if (errorMessage) { %>
    <div class="error-container">
      <%- errorMessage %>
    </div>
  <% } %>
  <div class="content-container">
    <h2>Login</h2>
    <div class="header-dash-line"></div>
    <form action="/login" method="POST" novalidate>
      <div class="my-form-control">
        <input type="email" name="email" id="email" placeholder="Your email"/>
        <div class="email-error"></div>
      </div>
      <div class="my-form-control reset-form-control">
        <input type="password" name="password" id="password" placeholder="Your password"/>
        <div class="password-error"></div>
      </div>
      <div class="login-options">
        <a href="/forget_password" class="reset-link">Forget Password</a>
        <a href="/register" class="reset-link">Do not have an account</a>
      </div>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
      <button class="btn">
        Login
      </button>
    </form>
  </div>
</section>

<%- include("../includes/footer.ejs"); %>
<%- include("../includes/bottom_part.ejs"); %>
