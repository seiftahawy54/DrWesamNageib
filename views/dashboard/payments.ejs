<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/dashboard/navbar.css"/>
<link rel="stylesheet" href="/css/dashboard/dashboard.css"/>
<link rel="stylesheet" href="/css/dashboard/courses.css"/>
<link rel="stylesheet" href="/css/dashboard/payments.css"/>
</head>
<body>

<section class="payments courses">
  <div class="container-fluid g-0">
    <div class="row g-0">
      <div class="col-3">
        <%- include("../includes/dashboard-navbar.ejs"); %>
      </div>
      <div class="col-9">
        <div class="content">
          <main class="content-header">
            <div class="custom-head">
              <h2>Payments</h2>
              <span></span>
            </div>
          </main>

          <div class="courses-data payments-data">
            <div class="table-head">
              <span class="payment-rank">Course Name</span>
              <span class="payment-name">Payee Name</span>
              <span class="payment-price">Status</span>
            </div>
            <% payments.forEach((payment, index) => { %>
              <div class="table-row">
                <span class="payment-rank"><%= courses[index].name; %></span>
                <span class="payment-name"><%= users[index].name; %></span>
                <span
                  class="payment-price"><%= payment.status; %></span>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../includes/bottom_part.ejs"); %>
