<%- include("../../includes/top_part.ejs"); %>
<!-- Dashboard Globals -->
<%- include("../../includes/dashboard_includes.ejs"); %>
<link rel="stylesheet" href="/css/dashboard/navbar.css" />
<link rel="stylesheet" href="/css/dashboard/dashboard.css" />
<link rel="stylesheet" href="/css/dashboard/courses.css" />
<link rel="stylesheet" href="/css/dashboard/exams.css" />
</head>
<body>
<section class="courses certificate">
  <div class="container-fluid g-0">
    <div class="row g-0">
      <div class="col-3">
        <%- include("../../includes/dashboard-navbar.ejs"); %>
      </div>
      <div class="col-9">
        <div class="content">
          <div class="custom-head">
            <h2>
              <% if (editMode === true) { %>
                <%= "Update exam" %>
              <% } else { %>
                <%= "Add new exam" %>
              <% } %>
            </h2>
            <span></span>
          </div>
          <%- include('../../includes/errorMessage.ejs'); %>
          <form
            action="/dashboard/<% if (editMode === true) { %><%= "edit-exams/" + exam.exam_id %><% } else { %>add-new-exams<% } %>"
            method="POST">

            <!-- Exam Status -->
            <%- include('../../includes/check-input.ejs', {id: "exam-status", checked: editMode && exam.status ? exam.status : "", label: "Exam Status", name: "exam-status" } ); %>

            <!-- Add New Exam Btn -->
            <div class="questions-container" id="questions-container">

            </div>

            <div class="my-3">
              <button class="btn" id="add-new-exam" type="button">
                Add new question
              </button>
            </div>

            <hr>

            <input type="hidden" name="_csrf" value="<%= csrfToken %>" id="csrfToken" />
            <button type="submit" class="btn submitBtn" id="submitBtn">
              <% if (editMode === true) { %>
                <%= "Update exam"; %>
              <% } else { %>
                <%= "Add new exam"; %>
              <% } %>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>


<button type="button" class="btn btn-primary d-none" data-bs-toggle="modal" data-bs-target="#exampleModal">
  Launch demo modal
</button>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel"
     aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">
          Add new exam
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" id='question-form'>
        <div class="modal-body">
          <%- include('../../includes/main-input.ejs', {
          type: "text",
          name: "question-header",
          placeholder: "question header",
          id: "question-header",
          label: "Question Title",
          value: "",
          custom: ["required"] }); %>
          <hr />
          <h5>Answers</h5>
          <div id="answers-container">
            <div class="input-group mb-3">
              <span class="input-group-text" id="answer-1">Answer 1</span>
              <input type="text" class="form-control" name="answer-1" placeholder="Answer 1" required />
            </div>

            <div class="input-group mb-3">
              <span class="input-group-text" id="answer-2">Answer 2</span>
              <input type="text" class="form-control" name="answer-2" placeholder="Answer 2" required />
            </div>

            <div class="input-group mb-3">
              <span class="input-group-text" id="answer-3">Answer 3</span>
              <input type="text" class="form-control" name="answer-3" placeholder="Answer 3" required />
            </div>

            <div class="input-group mb-3">
              <span class="input-group-text" id="answer-4">Answer 4</span>
              <input type="text" class="form-control" name="answer-4" placeholder="Answer 4" required />
            </div>
          </div>
          <hr>
          <%- include('../../includes/main-input.ejs', {
          type: "number",
          name: "question-answer",
          placeholder: "question answer",
          id: "correct-answer",
          label: "Correct Answer",
          value: "",
          custom: [`max="4" min="1" required`] }); %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
          <button type="submit" class="btn btn-primary" data-bs-target="#exampleModal"
                  id="save-question">Save changes
          </button>
          <button type="button" class="d-none" data-bs-dismiss="modal" id="hiddenDismissBtn"></button>
        </div>
      </form>
    </div>
  </div>
</div>


<script src="https://unpkg.com/axios/dist/axios.min.js"></script>
<script src="/js/bootstrap.bundle.min.js"></script>
<script src="/js/dashboard/exams_forms.js"></script>

<%- include("../../includes/bottom_part.ejs"); %>
