<%- include("../../includes/top_part.ejs"); %>
<!-- Dashboard Globals -->
<%- include("../../includes/dashboard_includes.ejs"); %>
<link rel="stylesheet" href="/css/dashboard/navbar.css"/>
<link rel="stylesheet" href="/css/dashboard/dashboard.css"/>
<link rel="stylesheet" href="/css/dashboard/courses.css"/>
<link rel="stylesheet" href="/css/dashboard/round_form.css">
</head>
<body>

<section class="rounds courses">
  <div class="container-fluid g-0">
    <div class="row g-0">
      <div class="col-3">
        <%- include("../../includes/dashboard-navbar.ejs"); %>
      </div>
      <div class="col-9">
        <div class="content">
          <div class="custom-head">
            <h2>
              <% if (editMode === true) { %>
                <%= "Update Round"; %>
              <% } else { %>
                <%= "Add new round"; %>
              <% } %>
            </h2>
            <span></span>
          </div>
          <%- include('../../includes/errorMessage.ejs'); %>
          <form
            action="/dashboard/<% if (editMode === true) { %><%= "edit-round/" + round.round_id %><% } else { %>start-new-round<% } %>"
            method="POST">
            <select name="round_course" class="form-control my-3"
                    id="enrolled-course" <%- editMode ? 'disabled' : "" %>>
              <% if (editMode === true) { %>
                <% courses.forEach(course => { %>
                  <option <%- round.round_course === course.name ? 'selected=""' : "" %>
                    value="<%- course.course_id %>">
                    <%= course.name %>
                  </option>
                <% }) %>
              <% } else { %>
                <option selected="<%- Object.keys(round).length === 0 ? 'selected' : "" %>" value="">
                  Please Select A Course
                </option>
                <% courses.forEach(course => { %>
                  <option <%- round.round_course === course.name ? 'selected=""' : "" %>
                    value="<%- course.course_id %>">
                    <%= course.name %>
                  </option>
                <% }) %>

                <% if (validationErrors.find(e => e.param === 'round_course')) { %>
                  <div class="alert alert-danger" role="alert">
                    Please Select a course!
                  </div>
                <% } %>
              <% } %>
            </select>

            <div class="form-floating my-3">
              <input type="date" name="round_date" placeholder="Round Date"
                     class="form-control <%= validationErrors.find(e => e.param === 'round_date') ? "is-invalid" : "" %>"
                     value="<% if (editMode === true) { %><%= moment(round.round_date).format("MM/DD/YYYY") %><% } %>"
                     id="round_date"/>
              <label for="round_date">Round Date</label>
            </div>

            <div>
              <% if (editMode === true) { %>
                <div class="btn-group my-3 users-select-button" role="group"
                     aria-label="Basic radio toggle button group">
                  <h3>Current Round People</h3>
                  <% roundUsers.forEach((user, index) => { %>
                    <input class="btn-check" checked="checked"
                           type="checkbox"
                           id="user-<%- index %>"
                           name="user-<%- index %>" value="<%= user.user_id %>">
                    <label class="btn-outlined btn-outline-primary" for="user-<%- index %>">
                      <%- user.name %>
                    </label>
                  <% }) %>
                </div>
                <hr>
                <h3>Un-rounded People</h3><br/>
                <div class="btn-group my-3 users-select-button" role="group">
                  <% usersArr.forEach((user, index) => { %>
                    <% if (user.current_round === null) { %>
                      <input class="btn-check" type="checkbox"
                             id="user-<%- index %>"
                             name="user-<%- index %>" value="<%= user.user_id %>">
                      <label class="btn-outlined btn-outline-primary" for="user-<%- index %>">
                        <%- user.name %>
                      </label>
                    <% } %>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <input type="hidden" name="_csrf" value="<%= csrfToken; %>"/>
            <button type="submit" class="btn submitBtn">
              <% if (editMode === true) { %>
                <%= "Update Round"; %>
              <% } else { %>
                <%= "Start new round"; %>
              <% } %>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../../includes/bottom_part.ejs"); %>
