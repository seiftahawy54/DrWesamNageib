<%- include("../includes/top_part.ejs"); %>
<link rel="stylesheet" href="/css/home.css" />
<link href="https://unpkg.com/swiper@7/swiper-bundle.min.css" rel="stylesheet" />
</head>
<body>
<%- include("../includes/navigation.ejs"); %>

<!-- Start main header Section -->
<section class="main-header">
  <div class="container">
    <%- include("../includes/errorMessage.ejs"); %>
    <p>Welcome to Dr. Wesam Nageib's webiste</p>
    <h2>Your way to find success in your career</h2>
    <video src="/videos/intro_vid.mp4" autoplay controls></video>
    <div class="button-container">
      <a class="btn" href="/courses">Browse Courses</a>
      <a class="btn" href="https://www.youtube.com/channel/UCk_rc4hmGJgBhZj9bQMwYDA/videos" target="_blank">Free
        Trial</a>
    </div>
    <div class="courses-scroll">
      Our Courses
      <%- include('../../public/imgs/svgs/down_arrow.svg') %>
    </div>
  </div>
</section>
<!-- End main header Section -->
<!-- Start Our Courses Sections -->
<section class="our-courses">
  <div class="container">
    <% courses.forEach((course, index) => { %>
      <div class="row courses-container justify-content-center">
        <div class="course-text col">
          <h3 class="course-title-en"><%- course.name %></h3>
          <h3 class="course-title-ar"><%- course.ar_course_name %></h3>
          <p class="ar-font">
            <%- course.description %>
          </p>
          <div class="button-container">
            <a class="btn" href="/courses/<%- course.course_id %>">View Course</a>
            <a class="btn" href="https://www.youtube.com/channel/UCk_rc4hmGJgBhZj9bQMwYDA/videos" target="_blank">
              Sample Session
            </a>
          </div>
        </div>
        <div class="course-thumbnail col ">
          <img src="/downloaded_images/<%- course.course_img %>" alt="<%- course.name %>" />
        </div>
      </div>
    <% }) %>
  </div>
</section>
<!-- End Our Courses Sections -->
<!-- Start JoinUs Section -->

<section class="join-us">
  <div class="overlay">
    <div class="container">
      <div class="text-center">
        <h2>Make the best decision you could ever take in your career right now!</h2>
        <p>Meet your expectations with our best in-game, highly trained, and well-skilled instructors.</p>
        <a class="btn reset-link d-inline-flex" href="/courses">Join Now</a>
      </div>
    </div>
  </div>
</section>

<!-- End JoinUs Section -->
<!-- Start info section -->
<section class="info-section">
  <p class="text-center"><a href="mailto:drwesamnageib@gmail.com" class="reset-link" target="_blank">drwesamnageib@gmail.com</a>
  </p>
</section>
<!-- End info section -->
<!-- Start Floating Whatsapp -->

<div class="floating-whatsapp">
  <a href="https://wa.me/966548794731">
    <%- include("../../public/imgs/svgs/whatsapp.svg"); %>
  </a>
</div>

<!-- End Floating Whatsapp -->
<!-- Start Social Media -->

<section class="social-media">
  <a href="https://www.facebook.com/groups/690198168518293/?ref=share" class="reset-link" target="_blank">
    <%- include("../../public/imgs/svgs/social_media/facebook.svg"); %>
  </a>
  <a href="https://www.linkedin.com/in/wesam-nageib-00132116a" class="reset-link" target="_blank">
    <%- include("../../public/imgs/svgs/social_media/linkedin.svg"); %>
  </a>
  <a href="https://t.me/joinchat/HIXyqBaQ6su0JL3Q3jzjNg" class="reset-link" target="_blank">
    <%- include("../../public/imgs/svgs/social_media/telegram.svg"); %>
  </a>
  <a href="https://youtube.com/channel/UCk_rc4hmGJgBhZj9bQMwYDA" class="reset-link" target="_blank">
    <%- include("../../public/imgs/svgs/social_media/youtube.svg"); %>
  </a>
</section>

<!-- End Social Media -->

<%- include("../includes/footer.ejs"); %>

<script async type="module">
  import Swiper from "https://unpkg.com/swiper@7/swiper-bundle.esm.browser.min.js"

  const swiper = new Swiper(".main-slider", {
    loop: true,
    autoplay: true,
    // If we need pagination
    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },

    // Navigation arrows
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
    slidesPerView: 1,
  })

</script>

